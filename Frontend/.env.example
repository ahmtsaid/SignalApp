# ──────────────────────────────────────────────────────────────────────────────
# Bu dosyayı kopyalayıp ".env" olarak kaydet, gerçek değerleri gir.
# .env dosyası asla Git'e commit edilmez (.gitignore'da olmalı).
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — Project Settings → API
# Authentication → Providers → Anonymous: Enable (kayıt ekranı kapalıyken gerekli)
EXPO_PUBLIC_SUPABASE_URL=https://YOURPROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# .NET Backend URL — Railway/Render deploy sonrası alınan URL
EXPO_PUBLIC_API_URL=https://signalapp-api.up.railway.app
